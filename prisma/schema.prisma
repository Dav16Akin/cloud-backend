generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//USER
model User {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  phoneNumber String

  companyName   String
  address       String
  country       String
  city          String
  postcode      String

  role        Role     @default(USER)
  verified    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  otps        OTP[]
  hostingAccounts HostingAccount[]
  orders Order[]
}

enum Role {
  USER
  ADMIN
  SUPPORT
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

model OTP {
  id String @id @default(uuid())
  userId String
  code String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts  Int @default(0)
}

//PLAN
model Plan {
  id          String   @id @default(cuid())
  name        String   // "Starter" | "Business" | "Agency"
  price       Float    // in Naira
  billingCycle String  // "yearly"
  storage     String   // "2GB SSD"
  bandwidth   String   // "10GB"
  websites    Int      // 1, 5, unlimited = 999
  emails      Int      // 2, 10, unlimited = 999
  features    String[] // array of feature strings
  isPopular   Boolean  @default(false) // highlights Business plan
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hostingAccounts HostingAccount[]
  orders Order[]
}


//HOSTING
model HostingAccount {
  id            String   @id @default(cuid())
  userId        String
  planId        String
  
  // cPanel account details
  cpanelUsername String  @unique
  domain         String  @unique
  serverIp       String
  
  status        HostingStatus @default(ACTIVE)
  expiresAt     DateTime
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan     @relation(fields: [planId], references: [id])
  orderId   String? @unique
  order     Order?  @relation(fields: [orderId], references: [id])
}


enum HostingStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
  PENDING
}


model Order {
  id             String         @id @default(cuid())
  userId         String
  planId         String
  amount         Float
  status         OrderStatus    @default(PENDING)
  paystackRef    String         @unique
  paystackData   Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           Plan           @relation(fields: [planId], references: [id])
  hostingAccount HostingAccount?
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}