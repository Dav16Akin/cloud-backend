generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  fullName    String
  email       String   @unique
  password    String
  role        Role     @default(USER)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  phoneNumber String
}

enum Role {
  USER
  ADMIN
  SUPPORT
}
